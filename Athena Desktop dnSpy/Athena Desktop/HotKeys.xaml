<Window
	x:Class="Athena.App.W7.HotKeys" xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" xmlns:d="http://schemas.microsoft.com/expression/blend/2008" xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" xmlns:local="clr-namespace:Athena.App.W7"
	Title="Global Hot Key Assignments"
	Height="700"
	Width="500"
	Icon="Assets/Athena.ico"
	WindowStartupLocation="CenterOwner"
	MinWidth="500"
	MinHeight="700"
	HorizontalContentAlignment="Stretch"
	ResizeMode="NoResize"
	Topmost="True"
	MaxWidth="500"
	MaxHeight="700"
	Closing="Window_Closing">
	<Grid
		Margin="5,5,5,5">
		<Grid.RowDefinitions>
			<RowDefinition />
			<RowDefinition />
			<RowDefinition />
			<RowDefinition />
			<RowDefinition />
			<RowDefinition />
			<RowDefinition />
			<RowDefinition />
			<RowDefinition />
			<RowDefinition />
			<RowDefinition />
			<RowDefinition />
			<RowDefinition />
			<RowDefinition />
			<RowDefinition />
			<RowDefinition />
			<RowDefinition />
			<RowDefinition />
			<RowDefinition />
		</Grid.RowDefinitions>
		<Grid.ColumnDefinitions>
			<ColumnDefinition
				Width="125" />
			<ColumnDefinition />
		</Grid.ColumnDefinitions>
		<Label
			Grid.Row="0"
			Grid.Column="0"
			VerticalAlignment="Center"
			HorizontalAlignment="Center"
			Grid.ColumnSpan="2">Click on a textbox to set a hotkey. Hit 'escape' to clear it.</Label>
		<Label
			Grid.Row="1"
			Grid.Column="0"
			VerticalAlignment="Center">Start Toggle:</Label>
		<Label
			Grid.Row="2"
			Grid.Column="0"
			VerticalAlignment="Center">Record Toggle:</Label>
		<Label
			Grid.Row="3"
			Grid.Column="0"
			VerticalAlignment="Center">Follow Toggle:</Label>
		<Label
			Grid.Row="4"
			Grid.Column="0"
			VerticalAlignment="Center">Next Unit:</Label>
		<Label
			Grid.Row="5"
			Grid.Column="0"
			VerticalAlignment="Center">Prev Unit:</Label>
		<Label
			Grid.Row="6"
			Grid.Column="0"
			VerticalAlignment="Center">Zoom In:</Label>
		<Label
			Grid.Row="7"
			Grid.Column="0"
			VerticalAlignment="Center">Zoom Out:</Label>
		<Label
			Grid.Row="8"
			Grid.Column="0"
			VerticalAlignment="Center">Pan Left:</Label>
		<Label
			Grid.Row="9"
			Grid.Column="0"
			VerticalAlignment="Center">Pan Right:</Label>
		<Label
			Grid.Row="10"
			Grid.Column="0"
			VerticalAlignment="Center">Pan Up:</Label>
		<Label
			Grid.Row="11"
			Grid.Column="0"
			VerticalAlignment="Center">Pan Down:</Label>
		<Label
			Grid.Row="12"
			Grid.Column="0"
			VerticalAlignment="Center">Locations Toggle:</Label>
		<Label
			Grid.Row="13"
			Grid.Column="0"
			VerticalAlignment="Center">Grid Toggle:</Label>
		<Label
			Grid.Row="14"
			Grid.Column="0"
			VerticalAlignment="Center">Ink Toggle:</Label>
		<Label
			Grid.Row="15"
			Grid.Column="0"
			VerticalAlignment="Center">Markers Toggle:</Label>
		<Label
			Grid.Row="16"
			Grid.Column="0"
			VerticalAlignment="Center">Units Toggle:</Label>
		<Label
			Grid.Row="17"
			Grid.Column="0"
			VerticalAlignment="Center">Groups Toggle:</Label>
		<TextBox
			Name="start"
			Grid.Row="1"
			Grid.Column="1"
			VerticalAlignment="Center"
			Tag="start"
			IsReadOnly="False"
			KeyDown="TextKeyDown" />
		<TextBox
			Name="recordstart"
			Grid.Row="2"
			Grid.Column="1"
			VerticalAlignment="Center"
			Tag="recordstart"
			IsReadOnly="False"
			KeyDown="TextKeyDown" />
		<TextBox
			Name="track"
			Grid.Row="3"
			Grid.Column="1"
			VerticalAlignment="Center"
			Tag="track"
			IsReadOnly="False"
			KeyDown="TextKeyDown" />
		<TextBox
			Name="unitnext"
			Grid.Row="4"
			Grid.Column="1"
			VerticalAlignment="Center"
			Tag="unitnext"
			IsReadOnly="False"
			KeyDown="TextKeyDown" />
		<TextBox
			Name="unitprev"
			Grid.Row="5"
			Grid.Column="1"
			VerticalAlignment="Center"
			Tag="unitprev"
			IsReadOnly="False"
			KeyDown="TextKeyDown" />
		<TextBox
			Name="zoomin"
			Grid.Row="6"
			Grid.Column="1"
			VerticalAlignment="Center"
			Tag="zoomin"
			IsReadOnly="False"
			KeyDown="TextKeyDown" />
		<TextBox
			Name="zoomout"
			Grid.Row="7"
			Grid.Column="1"
			VerticalAlignment="Center"
			Tag="zoomout"
			IsReadOnly="False"
			KeyDown="TextKeyDown" />
		<TextBox
			Name="panleft"
			Grid.Row="8"
			Grid.Column="1"
			VerticalAlignment="Center"
			Tag="panleft"
			IsReadOnly="False"
			KeyDown="TextKeyDown" />
		<TextBox
			Name="panright"
			Grid.Row="9"
			Grid.Column="1"
			VerticalAlignment="Center"
			Tag="panright"
			IsReadOnly="False"
			KeyDown="TextKeyDown" />
		<TextBox
			Name="panup"
			Grid.Row="10"
			Grid.Column="1"
			VerticalAlignment="Center"
			Tag="panup"
			IsReadOnly="False"
			KeyDown="TextKeyDown" />
		<TextBox
			Name="pandown"
			Grid.Row="11"
			Grid.Column="1"
			VerticalAlignment="Center"
			Tag="pandown"
			IsReadOnly="False"
			KeyDown="TextKeyDown" />
		<TextBox
			Name="layerlocations"
			Grid.Row="12"
			Grid.Column="1"
			VerticalAlignment="Center"
			Tag="layerlocations"
			IsReadOnly="False"
			KeyDown="TextKeyDown" />
		<TextBox
			Name="layergrid"
			Grid.Row="13"
			Grid.Column="1"
			VerticalAlignment="Center"
			Tag="layergrid"
			IsReadOnly="False"
			KeyDown="TextKeyDown" />
		<TextBox
			Name="layerink"
			Grid.Row="14"
			Grid.Column="1"
			VerticalAlignment="Center"
			Tag="layerink"
			IsReadOnly="False"
			KeyDown="TextKeyDown" />
		<TextBox
			Name="layermarkers"
			Grid.Row="15"
			Grid.Column="1"
			VerticalAlignment="Center"
			Tag="layermarkers"
			IsReadOnly="False"
			KeyDown="TextKeyDown" />
		<TextBox
			Name="layerunits"
			Grid.Row="16"
			Grid.Column="1"
			VerticalAlignment="Center"
			Tag="layerunits"
			IsReadOnly="False"
			KeyDown="TextKeyDown" />
		<TextBox
			Name="layergroups"
			Grid.Row="17"
			Grid.Column="1"
			VerticalAlignment="Center"
			Tag="layergroups"
			IsReadOnly="False"
			KeyDown="TextKeyDown" />
		<Button
			Grid.Row="18"
			Grid.Column="1"
			HorizontalAlignment="Right"
			VerticalAlignment="Center"
			Width="75"
			Click="Button_Click">OK</Button>
	</Grid>
</Window>
