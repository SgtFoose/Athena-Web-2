<UserControl
	x:Class="Athena.App.W7.anchor" xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
	Width="200" xmlns:w7="clr-namespace:Athena.App.W7">
	<Grid>
		<Grid.ColumnDefinitions>
			<ColumnDefinition
				Width="200" />
		</Grid.ColumnDefinitions>
		<Grid.RowDefinitions>
			<RowDefinition
				Height="60" />
			<RowDefinition
				Height="30" />
		</Grid.RowDefinitions>
		<!--Unknown connection ID: 1-->
		<Ellipse
			Name="outerRing"
			Grid.Row="0"
			Grid.Column="0"
			Height="50"
			Width="50"
			StrokeThickness="2"
			Stroke="#FF000000"
			HorizontalAlignment="Center"
			VerticalAlignment="Center">
			<Shape.Fill>
				<SolidColorBrush
					Opacity="0.1"
					Color="Black" />
			</Shape.Fill>
		</Ellipse>
		<!--Unknown connection ID: 2-->
		<Ellipse
			Name="innerRing"
			Grid.Row="0"
			Grid.Column="0"
			Height="6"
			Width="6"
			StrokeThickness="2"
			Stroke="#FF000000"
			HorizontalAlignment="Center"
			VerticalAlignment="Center" />
		<!--Unknown connection ID: 3-->
		<TextBlock
			Name="AnchorName"
			Grid.Row="1"
			Grid.Column="0"
			HorizontalAlignment="Center"
			Foreground="#FF000000"
			FontSize="20"
			FontWeight="SemiBold"
			VerticalAlignment="Top" />
	</Grid>
</UserControl>
