<UserControl
	x:Class="Athena.App.W7.MarkerToolIcon" xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" xmlns:d="http://schemas.microsoft.com/expression/blend/2008" xmlns:w7="clr-namespace:Athena.App.W7">
	<StackPanel
		Orientation="Horizontal">
		<!--Unknown connection ID: 1-->
		<Canvas
			Name="MarkerIconHolder"
			MinHeight="40"
			MinWidth="40" />
		<Border
			BorderBrush="#FF808080"
			BorderThickness="1"
			Width="Auto"
			Margin="10,0,0,0">
			<Grid
				Background="#FFFFFFFF"
				VerticalAlignment="Center">
				<Grid.ColumnDefinitions>
					<ColumnDefinition
						Width="30" />
					<ColumnDefinition
						Width="100" />
					<ColumnDefinition
						Width="5" />
				</Grid.ColumnDefinitions>
				<Grid.RowDefinitions>
					<RowDefinition
						Height="20" />
					<RowDefinition
						Height="20" />
					<RowDefinition
						Height="20" />
					<RowDefinition
						Height="20" />
					<RowDefinition
						Height="20" />
					<RowDefinition
						Height="20" />
					<RowDefinition
						Height="1" />
				</Grid.RowDefinitions>
				<TextBlock
					Grid.Column="0"
					Grid.Row="0"
					Text="Text:"
					VerticalAlignment="Center"
					FontSize="8"
					FontWeight="Bold"
					Padding="2,2,2,2" />
				<!--Unknown connection ID: 2-->
				<TextBox
					Name="txtText"
					Grid.Column="1"
					Grid.Row="0"
					VerticalAlignment="Center"
					FontSize="8"
					Height="16"
					Margin="5,0,0,0"
					VerticalContentAlignment="Center" />
				<TextBlock
					Grid.Column="0"
					Grid.Row="1"
					Text="Type:"
					VerticalAlignment="Center"
					FontSize="8"
					FontWeight="Bold"
					Padding="2,2,2,2" />
				<!--Unknown connection ID: 3-->
				<ComboBox
					Name="ddlType"
					Grid.Column="1"
					Grid.Row="1"
					VerticalAlignment="Center"
					FontSize="8"
					Height="16"
					Margin="5,0,0,0">
					<ComboBoxItem
						Tag="1"
						Content="Arrow" />
					<ComboBoxItem
						Tag="2"
						Content="Circle" />
					<ComboBoxItem
						Tag="3"
						Content="Destroy" />
					<ComboBoxItem
						Tag="4"
						Content="Dot"
						IsSelected="True" />
					<ComboBoxItem
						Tag="5"
						Content="End" />
					<ComboBoxItem
						Tag="6"
						Content="Flag" />
					<ComboBoxItem
						Tag="7"
						Content="Join" />
					<ComboBoxItem
						Tag="8"
						Content="Marker" />
					<ComboBoxItem
						Tag="9"
						Content="Objective" />
					<ComboBoxItem
						Tag="10"
						Content="Pickup" />
					<ComboBoxItem
						Tag="11"
						Content="Start" />
					<ComboBoxItem
						Tag="12"
						Content="Unknown" />
					<ComboBoxItem
						Tag="13"
						Content="Warning" />
					<ComboBoxItem
						Tag="14"
						Content="Circle" />
					<ComboBoxItem
						Tag="15"
						Content="Rectangle" />
				</ComboBox>
				<TextBlock
					Grid.Column="0"
					Grid.Row="2"
					Text="Color:"
					VerticalAlignment="Center"
					FontSize="8"
					FontWeight="Bold"
					Padding="2,2,2,2" />
				<!--Unknown connection ID: 4-->
				<ComboBox
					Name="ddlColor"
					Grid.Column="1"
					Grid.Row="2"
					VerticalAlignment="Center"
					FontSize="8"
					Height="16"
					Margin="5,0,0,0">
					<ComboBoxItem
						Tag="0"
						Content="Black"
						IsSelected="True" />
					<ComboBoxItem
						Tag="1"
						Content="Blue" />
					<ComboBoxItem
						Tag="2"
						Content="Green" />
					<ComboBoxItem
						Tag="3"
						Content="Purple" />
					<ComboBoxItem
						Tag="4"
						Content="Red" />
				</ComboBox>
				<TextBlock
					Grid.Column="0"
					Grid.Row="3"
					Text="Scope:"
					VerticalAlignment="Center"
					FontSize="8"
					FontWeight="Bold"
					Padding="2,2,2,2" />
				<!--Unknown connection ID: 5-->
				<ComboBox
					Name="ddlScope"
					Grid.Column="1"
					Grid.Row="3"
					VerticalAlignment="Center"
					FontSize="8"
					Height="16"
					Margin="5,0,0,0">
					<ComboBoxItem
						Tag="0"
						Content="Athena" />
					<ComboBoxItem
						Tag="1"
						Content="ARMA - Myself"
						IsSelected="True" />
					<ComboBoxItem
						Tag="2"
						Content="ARMA - Group" />
					<ComboBoxItem
						Tag="3"
						Content="ARMA - Side" />
					<ComboBoxItem
						Tag="4"
						Content="ARMA - Global" />
				</ComboBox>
				<TextBlock
					Grid.Column="0"
					Grid.Row="4"
					Text="Dir:"
					VerticalAlignment="Center"
					FontSize="8"
					FontWeight="Bold"
					Padding="2,2,2,2" />
				<!--Unknown connection ID: 6-->
				<Slider
					Name="sldDir"
					Grid.Column="1"
					Grid.Row="4"
					VerticalAlignment="Center"
					Padding="2,2,2,2"
					Margin="5,0,0,0"
					Value="0"
					Maximum="360"
					Interval="1" />
				<StackPanel
					Grid.Column="1"
					Grid.Row="5"
					Orientation="Horizontal"
					FlowDirection="RightToLeft">
					<!--Unknown connection ID: 7-->
					<Button
						Name="btnDone"
						Content="Done"
						FontSize="8"
						Height="16"
						Width="40"
						Margin="0,0,5,0" />
					<!--Unknown connection ID: 8-->
					<Button
						Name="btnCancel"
						Content="Cancel"
						FontSize="8"
						Height="16"
						Width="40" />
				</StackPanel>
			</Grid>
		</Border>
		<FrameworkElement.LayoutTransform>
			<!--Unknown connection ID: 9-->
			<ScaleTransform
				x:Name="ToolScale" />
		</FrameworkElement.LayoutTransform>
	</StackPanel>
</UserControl>
